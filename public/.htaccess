# Laravel public/.htaccess (Bluehost-safe)
#
# IMPORTANT: After you upload/replace this file, open cPanel → MultiPHP Manager,
# select dugsierp.dispatchagency1.com, choose PHP 8.3 (ea-php83), click Apply.
# That adds the correct PHP handler lines. If you skip that step, Composer will
# say: "require a PHP version >= 8.3.0" because Apache falls back to old PHP.
#
# Do not add Options / php_value / php_flag here (they often cause HTTP 500).

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
